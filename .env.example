# 默认完全离线生成，无需 OpenAI 账号。改成 openai 时才需要填写密钥。
CONTENT_MODE=template
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# 部署时改为真实 GitHub Pages 地址
SITE_NAME=科技工具推荐
SITE_DESCRIPTION=每天发现值得关注的科技产品与效率工具
SITE_URL=https://your-name.github.io/your-repo

# 可选：统一联盟链接；留空则使用 Product Hunt 原始链接
AFFILIATE_LINK=
CUSTOM_DOMAIN=

# 首次建议设为 1 控制成本；0 表示处理全部新产品
MAX_PRODUCTS_PER_RUN=1
PRODUCT_HUNT_FEED_URL=https://www.producthunt.com/feed.rss
REQUEST_TIMEOUT_SECONDS=20
OPENAI_RETRY_DELAY_SECONDS=2
LOG_LEVEL=INFO
PROCESSED_IDS_FILE=processed_ids.txt
